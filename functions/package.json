{
  "name": "simulaconcurso-functions",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
